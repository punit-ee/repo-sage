# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Optional: Customize OpenAI model (default: gpt-4o-mini)
# For OpenAI: gpt-4o-mini, gpt-4, gpt-3.5-turbo
# For OpenRouter: openai/gpt-4o-mini, anthropic/claude-3-sonnet, meta-llama/llama-3-70b, etc.
# OPENAI_MODEL=gpt-4o-mini

# Optional: Customize temperature (default: 0.1)
# OPENAI_TEMPERATURE=0.1

# Optional: Customize max tokens (default: 4000)
# OPENAI_MAX_TOKENS=4000
